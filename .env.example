# ===============================================
# Task Manager - Environment Configuration
# ===============================================
# Copy this file to .env and update values for your environment
#
# NOTE: When running OUTSIDE Docker (make dev), use localhost ports
# When running INSIDE Docker (docker-compose up), use service names

# ===============================================
# Server Configuration
# ===============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s

# gRPC server port (separate from HTTP)
GRPC_PORT=9090

# ===============================================
# Database Configuration (PostgreSQL)
# ===============================================
# For local development (make dev): use localhost:5433
# For Docker (docker-compose): use postgres:5432
DB_HOST=localhost
DB_PORT=5433
DB_USER=taskmanager
DB_PASSWORD=taskmanager_secret
DB_NAME=taskmanager
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m


# ===============================================
# Redis Configuration
# ===============================================
# For local development: localhost:6379
# For Docker: redis:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5


# ===============================================
# Kafka Configuration (Redpanda)
# ===============================================
# For local development: localhost:9092
# For Docker: kafka:9092
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=taskmanager
KAFKA_AUTO_OFFSET_RESET=earliest


# ===============================================
# S3/MinIO Configuration
# ===============================================
# For local development: http://localhost:9000
# For Docker: http://minio:9000
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_BUCKET=taskmanager
S3_USE_PATH_STYLE=true


# ===============================================
# JWT Configuration
# ===============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h
JWT_ISSUER=taskmanager

# ===============================================
# OpenTelemetry Configuration
# ===============================================
OTEL_SERVICE_NAME=taskmanager
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_ENDPOINT=localhost:4317
OTEL_ENABLED=false

# ===============================================
# Logging
# ===============================================
LOG_LEVEL=info
LOG_FORMAT=json

# Optional Docker Compose published ports
APP_PORT=8080
POSTGRES_EXTERNAL_PORT=5433
REDIS_EXTERNAL_PORT=6379
KAFKA_EXTERNAL_PORT=9092
KAFKA_ADMIN_EXTERNAL_PORT=9644
MINIO_API_EXTERNAL_PORT=9000
MINIO_CONSOLE_EXTERNAL_PORT=9001
